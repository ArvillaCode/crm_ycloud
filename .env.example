# Environment Configuration Template
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=whatsapp_crm

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET=replace_this_with_a_secure_random_string_in_production

# Third-party Integrations
YCLOUD_API_KEY=your_ycloud_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# Storage Configurations (local, s3)
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
