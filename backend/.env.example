# Node Environment
NODE_ENV=development
PORT=5000

# Database Settings
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=whatsapp_crm

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Config
JWT_SECRET=supersecretjwtkey

# YCloud API & WhatsApp Cloud API Configurations
YCLOUD_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
YCLOUD_ENABLED=false
WHATSAPP_SEND_ENABLED=false

# Storage Settings (local, s3)
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
